# ─── Roadtrippers Test Environment ───────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit credentials.

# ─── App URLs ─────────────────────────────────────────────────────────────────
BASE_URL=https://maps.roadtrippers.com

# ─── Test Credentials ─────────────────────────────────────────────────────────
# Create a dedicated test account at roadtrippers.com — never use a real account
TEST_EMAIL=your-test@example.com
TEST_PASSWORD=your-test-password

# ─── AskUI credentials (from https://app.askui.com) ──────────────────────────
ASKUI_WORKSPACE_ID=your-workspace-id
ASKUI_TOKEN=your-token

# ─── Browser settings ─────────────────────────────────────────────────────────
HEADLESS=true
STORAGE_STATE=config/state/auth.json

# ─── CI mode ──────────────────────────────────────────────────────────────────
# CI=true  # set by CI providers automatically
