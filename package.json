{
  "name": "roadtrippers-playwright-askui",
  "version": "1.0.0",
  "description": "Playwright + TypeScript + AskUI + Cucumber BDD tests for Roadtrippers trip planning",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:happy": "playwright test --grep @happy",
    "test:edge": "playwright test --grep @edge",
    "test:error": "playwright test --grep @error",
    "test:smoke": "playwright test --grep @smoke",
    "report": "playwright show-report playwright-report",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "bdd": "cucumber-js",
    "bdd:smoke": "cucumber-js --tags @smoke",
    "bdd:happy": "cucumber-js --tags @happy",
    "bdd:edge": "cucumber-js --tags @edge",
    "bdd:error": "cucumber-js --tags @error",
    "bdd:headed": "cross-env HEADLESS=false cucumber-js",
    "bdd:report": "npx allure generate reports/allure-results --clean -o reports/allure-report && npx allure open reports/allure-report",
    "bdd:dry-run": "cucumber-js --dry-run",
    "bdd:debug": "cross-env PWDEBUG=1 cucumber-js",
    "auth:export": "tsx scripts/export-cookies.ts",
    "auth:capture": "tsx scripts/capture-auth.ts",
    "auth:check": "node -e \"const f=require('./config/state/auth.json');const n=f.cookies&&f.cookies.length;console.log(n?'✅ auth.json has '+n+' cookies — session looks valid':'❌ auth.json is empty — run: npm run auth:export -- --help')\""
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.0.0",
    "@cucumber/pretty-formatter": "^1.0.1",
    "@playwright/test": "^1.41.0",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "allure-commandline": "^2.29.0",
    "allure-cucumberjs": "^3.0.4",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.1",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "askui": "^0.20.0",
    "playwright": "^1.41.0",
    "ws": "^8.20.0"
  }
}
